# Workflow Development Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# LLM Configuration (for agent.complete())
# ===========================================

# OpenAI API Key - Required for LLM completions
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI Base URL - Optional, for custom API endpoint
# Examples:
#   - Alibaba DashScope: https://dashscope.aliyuncs.com/compatible-mode/v1
#   - Ollama: http://localhost:11434/v1
#   - vLLM: http://localhost:8000/v1
#   - Azure OpenAI: https://your-resource.openai.azure.com/openai/deployments/your-deployment
OPENAI_BASE_URL=

# Local Model Name - Optional, defaults to 'gpt-4o-mini'
# Examples:
#   - OpenAI: gpt-4o, gpt-4-turbo, gpt-4o-mini
#   - DashScope: qwen-turbo, qwen-plus, qwen-max, glm-5
#   - Ollama: llama3.1, qwen2.5, deepseek-coder
LOCAL_MODEL=gpt-4o-mini

# ===========================================
# Chrome DevTools Protocol Configuration
# ===========================================

# CDP Base URL - Chrome DevTools Protocol endpoint
# Default: http://localhost:9222/json/api
CDP_BASE_URL=http://localhost:9222/json/api

# ===========================================
# Optional Settings
# ===========================================

# Debug mode - Set to 'true' to enable verbose logging
# DEBUG=true